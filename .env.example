# Database
POSTGRES_DB=cookhelp
POSTGRES_USER=cookhelp
POSTGRES_PASSWORD=cookhelp
DATABASE_URL=postgresql+asyncpg://cookhelp:cookhelp@localhost:5432/cookhelp

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Telegram Bot
BOT_TOKEN=your_bot_token_here

# App
LOG_LEVEL=INFO
ENVIRONMENT=development

# Embedding (will be set after testing model)
EMBEDDING_DIMENSION=2048
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free